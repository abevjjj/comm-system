<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:orientation="vertical">

    <!-- 顶部状态条 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#161B22"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▣ 消息调度台"
            android:textColor="#E6EDF3"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/connDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/dot_offline" />

        <TextView
            android:id="@+id/connLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="连接中…"
            android:textColor="#6E7681"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/logoutBtn"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_lock_power_off"
            app:tint="#9AA6B2" />

    </LinearLayout>

    <!-- 联系人列表 + 聊天区：用 ViewFlipper 简化双视图切换，避免引入 Fragment 复杂度 -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 视图0: 联系人列表 -->
        <ListView
            android:id="@+id/contactListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#21262D"
            android:dividerHeight="1dp" />

        <!-- 视图1: 聊天区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="#161B22"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <ImageButton
                    android:id="@+id/backBtn"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_rew"
                    app:tint="#9AA6B2" />

                <TextView
                    android:id="@+id/chatPeerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#E6EDF3"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ListView
                android:id="@+id/messageListView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="@null"
                android:paddingHorizontal="10dp"
                android:transcriptMode="alwaysScroll"
                android:stackFromBottom="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#161B22"
                android:orientation="horizontal"
                android:padding="8dp">

                <EditText
                    android:id="@+id/messageInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="输入消息…"
                    android:textColorHint="#6E7681"
                    android:maxLines="4"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp"
                    android:textColor="#E6EDF3"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/sendBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_btn_primary"
                    android:paddingHorizontal="16dp"
                    android:text="发送"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

    </ViewFlipper>

</LinearLayout>
